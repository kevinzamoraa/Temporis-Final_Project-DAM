<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.TemporisAndroidApp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>

        <item name="postSplashScreenTheme">@style/Theme.TemporisAndroidApp</item>
    </style>
    <style name="RoundedCornersDialog" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_dialog_rounded</item>
    </style>

    <style name="Theme.Temporis.HighContrast" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">#000000</item>
        <item name="colorSurface">#000000</item>

        <item name="colorOnSurface">#FFFFFF</item>
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorOnPrimary">#000000</item>

        <item name="colorSecondary">#FFFF00</item>
        <item name="colorOnSecondary">#000000</item>

        <item name="cardViewStyle">@style/HighContrastCard</item>
    </style>

    <style name="HighContrastCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">#000000</item>
        <item name="strokeColor">#FFFFFF</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:padding="16sp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configuración"
            android:textColor="?attr/colorPrimary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_profile"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64sp"
            android:text="Perfil de Usuario"
            android:textColor="?attr/colorOnSurface"
            android:gravity="start|center_vertical"
            app:iconTint="?attr/colorPrimary"
            app:icon="@drawable/ic_home" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_accessibility"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64sp"
            android:layout_marginTop="8sp"
            android:text="Accesibilidad"
            android:textColor="?attr/colorOnSurface"
            android:gravity="start|center_vertical"
            app:iconTint="?attr/colorPrimary"
            app:icon="@drawable/ic_watch" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_general_settings"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64sp"
            android:layout_marginTop="8sp"
            android:text="Ajustes Generales"
            android:textColor="?attr/colorOnSurface"
            android:gravity="start|center_vertical"
            app:iconTint="?attr/colorPrimary"
            app:icon="@drawable/ic_bar_chart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_app_info"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64sp"
            android:layout_marginTop="8sp"
            android:text="Info de la Aplicación"
            android:textColor="?attr/colorOnSurface"
            android:gravity="start|center_vertical"
            app:iconTint="?attr/colorPrimary"
            app:icon="@drawable/ic_hamburger_menu" />

        <View
            android:layout_width="match_parent"
            android:layout_height="32sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="64sp"
            android:text="Cerrar Sesión"
            android:textColor="?attr/colorOnPrimary"
            app:backgroundTint="?attr/colorPrimary"
            app:icon="@drawable/ic_logout"
            app:iconTint="?attr/colorOnPrimary" />

    </LinearLayout>
</ScrollView>
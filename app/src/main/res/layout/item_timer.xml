<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/timerCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12sp"
    android:layout_marginVertical="6sp"
    app:cardCornerRadius="16sp"
    app:cardElevation="4sp"
    app:cardBackgroundColor="?attr/colorSurface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16sp">

        <TextView
            android:id="@+id/timerName"
            android:layout_width="0sp"
            android:layout_height="wrap_content"
            android:text="Nombre del temporizador"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintEnd_toStartOf="@+id/timerDuration"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/timerDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8sp"
            android:text="20 min"
            android:textColor="?attr/colorPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/timerName"
            app:layout_constraintEnd_toStartOf="@+id/ivExpand"
            app:layout_constraintTop_toTopOf="@+id/timerName" />

        <ImageView
            android:id="@+id/ivExpand"
            android:layout_width="24sp"
            android:layout_height="24sp"
            android:src="@android:drawable/arrow_down_float"
            app:tint="?attr/colorOnSurface"
            app:layout_constraintBottom_toBottomOf="@+id/timerName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/timerName" />

        <TextView
            android:id="@+id/textViewCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12sp"
            android:minWidth="100sp"
            android:text="00:00"
            android:textColor="?attr/colorOnSurface"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/timerName" />

        <TextView
            android:id="@+id/timerCreatedAt"
            android:layout_width="0sp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="01/04/2026"
            android:textColor="?attr/colorOutline"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="@+id/textViewCountdown"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/textViewCountdown" />

        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="0sp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12sp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textViewCountdown">

            <ImageButton
                android:id="@+id/btnPlay"
                android:layout_width="48sp"
                android:layout_height="48sp"
                android:layout_marginHorizontal="12sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_play"
                app:tint="?attr/colorPrimary" />

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="48sp"
                android:layout_height="48sp"
                android:layout_marginHorizontal="12sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="48sp"
                android:layout_height="48sp"
                android:layout_marginHorizontal="12sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="?attr/colorOutline" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
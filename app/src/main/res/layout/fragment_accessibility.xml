<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16sp"
    android:background="?android:attr/windowBackground">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Accesibilidad"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?attr/colorPrimary"
        android:layout_marginBottom="16sp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16sp"
        app:cardElevation="4sp"
        app:cardBackgroundColor="?attr/colorSurface"
        android:layout_marginBottom="12sp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16sp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opciones de Visualización"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="8sp"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchHighContrast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Alto Contraste"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchBoldText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Texto en Negrita"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="8sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tamaño de fuente"
                android:layout_marginTop="16sp"/>

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderFontSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0.8"
                android:valueTo="1.4"
                android:stepSize="0.1"
                android:value="1.0" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>